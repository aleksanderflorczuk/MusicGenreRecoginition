{
  "python_version": "3.14.0",
  "random_seed": 30,
  "test_size": 0.2,
  "cv_splits": 5,
  "n_jobs": -1,
  "primary_metric": "accuracy",
  "target_column": "genre",
  "audio_dataset_environment_variable": "AUDIO_DATASET_PATH",
  "feature_file": "data/features_extended.csv",
  "output_directory": "docs",
  "baseline_models": {
    "logistic_regression": {
      "C": [0.1, 1.0, 10.0],
      "solver": ["lbfgs"]
    },
    "decision_tree": {
      "max_depth": [5, 10, null],
      "min_samples_leaf": [1, 3, 5]
    },
    "random_forest": {
      "n_estimators": [200, 500],
      "max_depth": [null, 15],
      "max_features": ["sqrt", "log2"]
    },
    "gradient_boosting": {
      "n_estimators": [100, 200],
      "learning_rate": [0.05, 0.1],
      "max_depth": [2, 3]
    }
  },
  "target_model": {
    "kernel": "rbf",
    "C": [1, 3, 10, 30, 100],
    "gamma": ["scale", 0.03, 0.01, 0.003, 0.001],
    "feature_selection_k": [20, 30, 40, 50, "all"]
  },
  "analysis": {
    "final_C": 3,
    "final_gamma": "scale",
    "permutation_repeats": 30,
    "stability_rows": 15
  }
}

